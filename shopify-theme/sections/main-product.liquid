<section class="section-6">
  <section class="section-7">
    <div class="div-block-48">
      <div class="div-block-49"><div><a href="{{ routes.all_products_collection_url }}">Shop all</a></div></div>
      <div class="div-block-50"><img src="{{ 'chevron-right.png' | asset_url }}" loading="lazy" alt=""></div>
      <div class="div-block-51"><div>{{ collection.title | default: 'Category' }}</div></div>
      <div class="div-block-52"><img src="{{ 'chevron-right.png' | asset_url }}" loading="lazy" alt=""></div>
      <div class="div-block-53"><div>{{ product.title }}</div></div>
      <div class="div-block-54"></div>
    </div>

    <div class="div-block-55">
      <div>
        <div class="div-block-58">
          <div class="div-block-57">
            {% assign thumb_media = product.media | where: 'media_type', 'image' %}
            {% for media in thumb_media limit: 4 %}
              <div class="div-block-59">
                {{ media | image_url: width: 200 | image_tag: loading: 'lazy', alt: product.title }}
              </div>
            {% endfor %}
          </div>
          <div class="div-block-56">
            {% if product.featured_image %}
              {{ product.featured_image | image_url: width: 1200 | image_tag: loading: 'lazy', class: 'image-15', alt: product.title }}
            {% else %}
              <img src="{{ 'Column.png' | asset_url }}" loading="lazy" alt="" class="image-15">
            {% endif %}
          </div>
        </div>

        <div class="div-block-61">
          <div class="div-block-66">
            <div class="text-block-18">Wirkung</div>
            <div class="div-block-62">
              <div class="div-block-63"><img src="{{ 'Frame-427319352.png' | asset_url }}" loading="lazy" alt=""></div>
              <div class="div-block-64"><img src="{{ 'Frame-427319353.png' | asset_url }}" loading="lazy" alt=""></div>
              <img src="{{ 'Frame-427319354.png' | asset_url }}" loading="lazy" alt="">
            </div>
          </div>
          <div class="div-block-67">
            <div class="text-block-18">Mögliche Nebenwirkungen</div>
            <div class="div-block-62">
              <div class="div-block-63"><img src="{{ 'Frame-427319352.png' | asset_url }}" loading="lazy" alt=""></div>
              <div class="div-block-64"><img src="{{ 'Frame-427319353.png' | asset_url }}" loading="lazy" alt=""></div>
              <img src="{{ 'Frame-427319354.png' | asset_url }}" loading="lazy" alt="">
            </div>
          </div>
          <div>
            <div class="text-block-18">Geschmack / Aroma</div>
            <div class="div-block-62">
              <div class="div-block-63"><img src="{{ 'Frame-427319352.png' | asset_url }}" loading="lazy" alt=""></div>
              <div class="div-block-64"><img src="{{ 'Frame-427319353.png' | asset_url }}" loading="lazy" alt=""></div>
              <img src="{{ 'Frame-427319354.png' | asset_url }}" loading="lazy" alt="">
            </div>
          </div>
        </div>
      </div>

      <div class="div-block-68">
        <div class="text-block-19"><strong class="bold-text-3">{{ product.title }}</strong></div>
        <div class="div-block-44">
          <p class="paragraph-6">{{ product.price | money }}</p>
          <p class="paragraph-7">inkl. MwSt.</p>
        </div>

        <div class="div-block-69">
          <div class="div-block-70">
            <img src="{{ 'Vector_1.png' | asset_url }}" loading="lazy" alt="">
            <img src="{{ 'Vector_1.png' | asset_url }}" loading="lazy" alt="">
            <img src="{{ 'Vector_1.png' | asset_url }}" loading="lazy" alt="">
            <img src="{{ 'Vector_1.png' | asset_url }}" loading="lazy" alt="">
            <img src="{{ 'Vector_1.png' | asset_url }}" loading="lazy" alt="">
          </div>
          <div class="div-block-71">
            <div>(4.5 stars)</div>
            <div>10 reviews</div>
          </div>
        </div>

        <p class="paragraph-10">{{ product.description | strip_html | truncate: 420 }}</p>

        <div class="form-block w-form">
          <div class="text-block-20">Menge</div>
          {% form 'product', product, class: 'form-2' %}
            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
            <input class="text-field-2 w-input" type="number" name="quantity" min="1" value="1">
            <button type="submit" name="add" class="div-block-47">
              <div class="text-block-17">In den Warenkorb</div><img loading="lazy" src="{{ 'Frame.png' | asset_url }}" alt="" class="image-13">
            </button>
          {% endform %}
        </div>

        <div class="text-block-21">kostenloser Versand ab 120€</div>

        <div class="div-block-73" id="ursprung">
          <div class="text-block-22">Ursprung &amp; Geschichte</div>
          <p class="paragraph-11">{{ product.description | strip_html }}</p>
        </div>

        <div class="w-embed">
          <div class="strain-map-wrapper" style="width: 100%; max-width: 900px; margin: auto; padding: 20px;">
            <svg viewbox="0 0 1000 800" xmlns="http://www.w3.org/2000/svg" style="width: 100%; height: auto; overflow: visible;">
              <g stroke="#E5E5E5" stroke-width="8">
                <line x1="150" y1="180" x2="850" y2="180"></line>
                <line x1="850" y1="180" x2="500" y2="600"></line>
                <line x1="500" y1="600" x2="150" y2="180"></line>
              </g>
              <g>
                <circle cx="150" cy="180" r="140" fill="#fb4c95"></circle>
                <text x="150" y="180" text-anchor="middle" fill="white" font-size="25" font-weight="600" dy=".3em" font-family="sans-serif">
                  Animal Mints #3
                </text>
              </g>
              <g>
                <circle cx="850" cy="180" r="140" fill="#42B0E6"></circle>
                <text x="850" y="180" text-anchor="middle" fill="white" font-size="25" font-weight="600" dy=".3em" font-family="sans-serif">
                  Zkittlez
                </text>
              </g>
              <g>
                <circle cx="500" cy="600" r="140" fill="black"></circle>
                <text x="500" y="600" text-anchor="middle" fill="white" font-size="25" font-weight="bold" dy=".3em" font-family="sans-serif">
                  {{ product.title }}
                </text>
              </g>
            </svg>
          </div>
        </div>
      </div>
    </div>
  </section>
</section>

{% schema %}
{
  "name": "Main Product",
  "settings": []
}
{% endschema %}
