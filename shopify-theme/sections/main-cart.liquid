<section class="section-6 cart-page">
  <section class="section-7">
    <div class="w-container">
      <h1>Cart</h1>

      {% if cart.item_count == 0 %}
        <p>Your cart is empty.</p>
        <p><a href="{{ routes.all_products_collection_url }}">Continue shopping</a></p>
      {% else %}
        <form action="{{ routes.cart_url }}" method="post" novalidate>
          <div class="cart-items" role="table" aria-label="Cart items">
            {% for item in cart.items %}
              <div class="cart-item" role="row">
                <div class="cart-item__image" role="cell">
                  <a href="{{ item.url }}">
                    {% if item.image %}
                      {{ item.image | image_url: width: 160 | image_tag: loading: 'lazy', alt: item.product.title }}
                    {% endif %}
                  </a>
                </div>

                <div class="cart-item__details" role="cell">
                  <div class="cart-item__title">
                    <a href="{{ item.url }}">{{ item.product.title }}</a>
                  </div>
                  {% unless item.variant.title == 'Default Title' %}
                    <div class="cart-item__variant">{{ item.variant.title }}</div>
                  {% endunless %}
                  <div class="cart-item__price">{{ item.final_price | money }}</div>
                  {% if item.selling_plan_allocation %}
                    <div class="cart-item__plan">{{ item.selling_plan_allocation.selling_plan.name }}</div>
                  {% endif %}
                  {% if item.properties != blank %}
                    <ul class="cart-item__properties">
                      {% for p in item.properties %}
                        {% assign first_char = p.first | slice: 0 %}
                        {% if p.last != blank and first_char != '_' %}
                          <li>{{ p.first }}: {{ p.last }}</li>
                        {% endif %}
                      {% endfor %}
                    </ul>
                  {% endif %}
                </div>

                <div class="cart-item__qty" role="cell">
                  <label class="visually-hidden" for="updates_{{ item.key }}">Quantity</label>
                  <input
                    id="updates_{{ item.key }}"
                    class="cart-qty"
                    type="number"
                    name="updates[]"
                    value="{{ item.quantity }}"
                    min="0"
                    inputmode="numeric"
                  >
                  <a class="cart-remove" href="{{ routes.cart_change_url }}?line={{ forloop.index }}&quantity=0">Remove</a>
                </div>

                <div class="cart-item__total" role="cell">
                  {{ item.final_line_price | money }}
                </div>
              </div>
            {% endfor %}
          </div>

          <div class="cart-summary">
            <div class="cart-summary__row">
              <span>Subtotal</span>
              <strong>{{ cart.total_price | money }}</strong>
            </div>

            {% if cart.cart_level_discount_applications.size > 0 %}
              <ul class="cart-discounts" aria-label="Cart discounts">
                {% for discount in cart.cart_level_discount_applications %}
                  <li>
                    <span>{{ discount.title }}</span>
                    <span>-{{ discount.total_allocated_amount | money }}</span>
                  </li>
                {% endfor %}
              </ul>
            {% endif %}

            <div class="cart-actions">
              <button class="cart-btn cart-btn--secondary" type="submit" name="update">Update cart</button>
              <button class="cart-btn cart-btn--primary" type="submit" name="checkout">Checkout</button>
            </div>

            {% if cart.note != nil %}
              <div class="cart-note">
                <label for="CartNote">Note</label>
                <textarea id="CartNote" name="note" rows="3">{{ cart.note }}</textarea>
              </div>
            {% endif %}
          </div>
        </form>
      {% endif %}
    </div>
  </section>
</section>

{% schema %}
{
  "name": "Main cart",
  "settings": []
}
{% endschema %}
